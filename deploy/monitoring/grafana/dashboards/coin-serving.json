{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "title": "Coin VLM - Serving",
  "uid": "coin-vlm-serving",
  "tags": ["coin-vlm", "serving"],
  "timezone": "",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "15s",
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Operational",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "stat",
      "title": "In-flight requests",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" } } },
      "targets": [
        { "expr": "coin_inflight_requests", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Request rate (req/s)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2 } },
      "targets": [
        { "expr": "sum(rate(coin_requests_total[1m]))", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Error ratio (5m)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(coin_requests_total{status!=\"ok\"}[5m])) / clamp_min(sum(rate(coin_requests_total[5m])), 1e-9)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Predict p95 (s)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 2 } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(coin_predict_latency_seconds_bucket[5m])) by (le))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request rate by status",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "stacking": { "mode": "normal" } } } },
      "targets": [
        {
          "expr": "sum by (status) (rate(coin_requests_total[1m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Latency",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }
    },
    {
      "type": "timeseries",
      "title": "End-to-end latency (server-side)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(coin_request_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(coin_request_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(coin_request_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Engine latency vs vLLM time-to-first-token",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(coin_predict_latency_seconds_bucket[5m])) by (le))", "legendFormat": "predict p95", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(vllm:time_to_first_token_seconds_bucket[5m])) by (le))", "legendFormat": "vLLM TTFT p95", "refId": "B" }
      ]
    },
    {
      "type": "row",
      "title": "Output drift (no ground truth at serve time)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 }
    },
    {
      "type": "timeseries",
      "title": "Parse failure ratio (5m)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } },
      "targets": [
        {
          "expr": "sum(rate(coin_parse_total{result=\"fail\"}[5m])) / clamp_min(sum(rate(coin_parse_total[5m])), 1e-9)",
          "legendFormat": "parse-fail",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Null-field ratio by field (5m)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } },
      "targets": [
        {
          "expr": "sum by (field) (rate(coin_prediction_null_total[5m])) / clamp_min(sum(rate(coin_parse_total[5m])), 1e-9)",
          "legendFormat": "{{field}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "vLLM engine",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 }
    },
    {
      "type": "timeseries",
      "title": "GPU KV-cache usage",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } },
      "targets": [
        { "expr": "vllm:kv_cache_usage_perc", "legendFormat": "kv-cache", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Requests running vs waiting",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "expr": "vllm:num_requests_running", "legendFormat": "running", "refId": "A" },
        { "expr": "vllm:num_requests_waiting", "legendFormat": "waiting", "refId": "B" }
      ]
    }
  ]
}
