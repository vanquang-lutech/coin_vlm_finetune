HF_TOKEN=your huggingface token here
WANDB_API_KEY=your wandb api key here

# MLflow (Phase 3 — hybrid tracking + registry). Server chạy trên server GPU.
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=coin-vlm-finetune
# Đừng để transformers tự upload checkpoint nặng mỗi lần save:
HF_MLFLOW_LOG_ARTIFACTS=0
# Mật khẩu Postgres backend của MLflow (docker-compose), KHÔNG commit giá trị thật:
MLFLOW_DB_PW=change-me

# Airflow (Step 4 — docker-compose.airflow.yml). KHÔNG commit giá trị thật.
AIRFLOW_DB_PW=change-me
# Sinh fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=
AIRFLOW_SECRET_KEY=change-me
# Host docker group gid (để Airflow dùng được docker.sock): getent group docker | cut -d: -f3
DOCKER_GID=999
# Host repo path + train image tag (DAG mount + spawn):
COIN_PROJECT_DIR=/data/coin/coin_vlm_finetune
COIN_TRAIN_IMAGE=coin-vlm-train:latest
