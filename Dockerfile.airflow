# Airflow image with the Docker provider so DAGs can run DockerOperator
# (spawn the coin-vlm-train container on the host via the mounted docker socket).
# See docs/mlops.md Mục 8.
FROM docker.m.daocloud.io/apache/airflow:2.10.4-python3.11

RUN pip install --no-cache-dir -i https://pypi.tuna.tsinghua.edu.cn/simple \
        "apache-airflow-providers-docker>=3.12,<4"
